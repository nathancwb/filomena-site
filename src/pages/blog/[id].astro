---
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---
<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content={post.data.description}>
    <title>{post.data.title} | Filomena Propaganda</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/styles.css">

    <style>
        /* =========================================
           BLOG POST PAGE - PREMIUM DESIGN
        ========================================= */

        .post-header {
            padding: 8rem 0 4rem;
            text-align: center;
        }

        .post-tag {
            font-size: 0.85rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.15em;
            color: var(--primary);
            margin-bottom: 1.5rem;
            display: inline-block;
        }

        .post-title {
            font-size: clamp(2.5rem, 6vw, 4.5rem);
            font-weight: 900;
            line-height: 1.1;
            margin-bottom: 2rem;
            max-width: 900px;
            margin-left: auto;
            margin-right: auto;
            color: var(--text);
        }

        .post-meta {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 1rem;
            font-size: 0.95rem;
            color: var(--text-muted);
            font-weight: 500;
        }

        .post-meta__divider {
            color: var(--border);
        }

        .post-author {
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }

        .post-author__avatar {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: var(--primary);
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-weight: 700;
        }

        /* Hero Image */
        .post-hero-image {
            max-width: 1000px;
            margin: 0 auto 5rem;
            border-radius: 24px;
            overflow: hidden;
            box-shadow: 0 20px 40px rgba(0,0,0,0.08);
        }

        .post-hero-image img {
            width: 100%;
            height: 60vh;
            object-fit: cover;
            display: block;
            background: var(--bg-alt);
        }

        /* Content Area */
        .post-content {
            max-width: 760px;
            margin: 0 auto;
            font-size: 1.15rem;
            line-height: 1.8;
            color: var(--text);
            padding-bottom: 6rem;
        }

        .post-content p {
            margin-bottom: 2rem;
        }

        .post-content h2 {
            font-family: var(--font-heading);
            font-size: 2.2rem;
            font-weight: 800;
            margin: 4rem 0 1.5rem;
            line-height: 1.2;
            color: var(--text);
        }

        .post-content h3 {
            font-size: 1.5rem;
            font-weight: 700;
            margin: 2.5rem 0 1rem;
        }

        .post-content strong {
            font-weight: 700;
            color: var(--text);
        }

        .post-content blockquote {
            margin: 3rem 0;
            padding: 2.5rem;
            border-left: 6px solid var(--primary);
            background: var(--bg-alt);
            border-radius: 0 16px 16px 0;
            font-size: 1.3rem;
            font-style: italic;
            font-weight: 600;
            line-height: 1.6;
            color: var(--text);
        }

        .post-content ul, .post-content ol {
            margin-bottom: 2rem;
            padding-left: 1.5rem;
        }

        .post-content li {
            margin-bottom: 0.75rem;
        }

        .post-content img {
            width: 100%;
            border-radius: 12px;
            margin: 3rem 0;
        }

        /* Share & Back */
        .post-footer {
            max-width: 760px;
            margin: 0 auto 6rem;
            padding-top: 3rem;
            border-top: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .share-links {
            display: flex;
            gap: 1rem;
            align-items: center;
        }

        .share-btn {
            width: 44px;
            height: 44px;
            border-radius: 50%;
            border: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--text);
            transition: all 0.3s ease;
        }

        .share-btn:hover {
            background: var(--primary);
            color: white;
            border-color: var(--primary);
        }

        .back-link {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            font-weight: 600;
            color: var(--text-muted);
            text-decoration: none;
            transition: color 0.3s ease;
        }

        .back-link:hover {
            color: var(--primary);
        }

        /* Recommended Posts */
        .recommended {
            background: var(--bg-alt);
            padding: 6rem 0;
        }

        .recommended__header {
            display: flex;
            align-items: flex-end;
            justify-content: space-between;
            margin-bottom: 3rem;
        }

        .recommended__title {
            font-size: 2.5rem;
            font-weight: 800;
        }

        .blog-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: var(--space-xl);
        }

        @media (max-width: 968px) {
            .blog-grid { grid-template-columns: repeat(2, 1fr); }
            .post-hero-image img { height: 40vh; }
            .post-footer { flex-direction: column; gap: 2rem; align-items: flex-start; }
        }
        @media (max-width: 576px) {
            .blog-grid { grid-template-columns: 1fr; }
        }
    </style>
</head>

<body>
    <div class="noise-overlay"></div>
    
    <!-- Header -->
    <header class="header">
        <div class="header__inner container">
            <a href="/" class="logo">
                <img src="/assets/images/logo-main.png" alt="Filomena Propaganda & Marketing" class="logo__img">
            </a>

            <nav class="nav">
                <ul class="nav__list" id="nav-menu">
                    <li><a href="/" class="nav__link">Home</a></li>
                    <li><a href="/sobre" class="nav__link">Sobre</a></li>
                    <li><a href="/servicos" class="nav__link">Serviços</a></li>
                    <li><a href="/portfolio" class="nav__link">Portfólio</a></li>
                    <li><a href="/blog" class="nav__link active">Blog</a></li>
                    <li><a href="/trabalhe-conosco" class="nav__link">Trabalhe Conosco</a></li>
                    <li><a href="/contato" class="nav__link">Contato</a></li>
                </ul>

                <div class="nav__actions">
                    <button class="menu-toggle" id="menu-toggle" aria-label="Menu">
                        <span></span><span></span><span></span>
                    </button>
                </div>
            </nav>
        </div>
    </header>

    <main>
        <!-- POST HEADER -->
        <article>
            <header class="post-header container">
                <span class="post-tag fade-in">{post.data.category}</span>
                <h1 class="post-title fade-in">{post.data.title}</h1>
                <div class="post-meta fade-in">
                    <div class="post-author">
                        <div class="post-author__avatar">{post.data.author.charAt(0)}</div>
                        <span>{post.data.author}</span>
                    </div>
                    <span class="post-meta__divider">•</span>
                    <span>{new Date(post.data.date).toLocaleDateString('pt-BR')}</span>
                    <span class="post-meta__divider">•</span>
                    <span>Leitura rápida</span>
                </div>
            </header>

            <div class="post-hero-image container fade-in">
                {post.data.thumbnail && <img src={post.data.thumbnail} alt={post.data.title}>}
            </div>

            <!-- POST CONTENT -->
            <div class="post-content fade-in container">
                <Content />
            </div>

            <!-- POST FOOTER / SHARE -->
            <div class="post-footer container fade-in">
                <a href="/blog" class="back-link">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"></path></svg>
                    Voltar para o blog
                </a>

                <div class="share-links">
                    <span style="font-weight: 600; font-size: 0.9rem; margin-right: 0.5rem;">Compartilhar:</span>
                    <a href="#" class="share-btn" aria-label="Compartilhar no WhatsApp">
