---
import { getCollection, getEntry } from 'astro:content';
const featuredProjects = (await getCollection('portfolio')).filter(p => p.data.featured);
const homePage = await getEntry('pages', 'home');
---
<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description"
        content="Filomena Propaganda - Agência de publicidade e marketing em São Carlos-SP. Comunicação criativa que conecta marcas a pessoas.">
    <title>Filomena Propaganda | Comunicação Criativa</title>

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&display=swap"
        rel="stylesheet">

    <link rel="stylesheet" href="/styles.css">
</head>

<body>
    <div class="noise-overlay"></div>
    <!-- Header -->
    <header class="header">
        <div class="header__inner container">
            <a href="/" class="logo">
                <img src="/assets/images/logo-main.png" alt="Filomena Propaganda & Marketing" class="logo__img">
            </a>

            <nav class="nav">
                <ul class="nav__list" id="nav-menu">
                    <li><a href="/" class="nav__link active">Home</a></li>
                    <li><a href="/sobre" class="nav__link">Sobre</a></li>
                    <li><a href="/servicos" class="nav__link">Serviços</a></li>
                    <li><a href="/portfolio" class="nav__link">Portfólio</a></li>
                    <li><a href="/blog" class="nav__link">Blog</a></li>
                    <li><a href="/trabalhe-conosco" class="nav__link">Trabalhe Conosco</a></li>
                    <li><a href="/contato" class="nav__link">Contato</a></li>
                </ul>

                <div class="nav__actions">
                    <button class="menu-toggle" id="menu-toggle" aria-label="Menu">
                        <span></span>
                        <span></span>
                        <span></span>
                    </button>
                </div>
            </nav>
        </div>
    </header>

    <main>
        <!-- Hero -->
        <section class="hero" id="home">
            <div class="container">
                <div class="hero__content">
                    <div class="hero__text">
                        <span class="hero__tag fade-in">Agência de Comunicação</span>
                        <h1 class="hero__title fade-in" set:html={homePage?.data?.hero_title || "Histórias que <span>conectam</span> marcas a pessoas."}>
                        </h1>
                        <p class="hero__description fade-in">
                            {homePage?.data?.hero_subtitle || "Transformamos ideias em comunicação estratégica. Há mais de 10 anos criando campanhas que geram resultados reais."}
                        </p>
                        <div class="hero__buttons fade-in">
                            <a href="#contato" class="btn btn--primary">Fale Conosco</a>
                            <a href="/portfolio" class="btn btn--outline">Ver Trabalhos</a>
                        </div>
                    </div>
                    <div class="hero__image fade-in">
                        <img src="/assets/images/fachada-filomena.png" alt="Fachada Filomena Propaganda">
                    </div>
                </div>
            </div>
        </section>

        <!-- Clientes – Faixa de logos -->
        <div class="clients-strip" aria-label="Nossos clientes">
            <div class="clients-strip__track">
                <!-- set 1 -->
                <div class="clients-strip__item item-bni">
                    <img src="/assets/images/client-bni.webp" alt="BNI" class="client-logo-img">
                </div>
                <div class="clients-strip__item item-alpha">
                    <img src="/assets/images/client-alpha.png" alt="Alpha Engenharia" class="client-logo-img">
                </div>
                <div class="clients-strip__item item-artfinal">
                    <img src="/assets/images/client-artfinal.png" alt="Art Final Marmoraria" class="client-logo-img">
                </div>
                <div class="clients-strip__item item-fukuhara">
                    <img src="/assets/images/client-fukuhara.jpg" alt="Fukuhara Studio Digital" class="client-logo-img">
                </div>
                <div class="clients-strip__item item-grampola">
                    <img src="/assets/images/client-grampola.png" alt="Grampola Peças Automotivas" class="client-logo-img">
                </div>
                <div class="clients-strip__item item-masotti">
                    <img src="/assets/images/client-masotti.webp" alt="Móveis Masotti" class="client-logo-img">
                </div>
                <div class="clients-strip__item item-jogoreal">
                    <img src="/assets/images/client-jogoreal.png" alt="Jogo Real" class="client-logo-img">
                </div>
                <!-- set 2 (duplicado para loop infinito) -->
                <div class="clients-strip__item item-bni" aria-hidden="true">
                    <img src="/assets/images/client-bni.webp" alt="" class="client-logo-img">
                </div>
                <div class="clients-strip__item item-alpha" aria-hidden="true">
                    <img src="/assets/images/client-alpha.png" alt="" class="client-logo-img">
                </div>
                <div class="clients-strip__item item-artfinal" aria-hidden="true">
                    <img src="/assets/images/client-artfinal.png" alt="" class="client-logo-img">
                </div>
                <div class="clients-strip__item item-fukuhara" aria-hidden="true">
                    <img src="/assets/images/client-fukuhara.jpg" alt="" class="client-logo-img">
                </div>
                <div class="clients-strip__item item-grampola" aria-hidden="true">
                    <img src="/assets/images/client-grampola.png" alt="" class="client-logo-img">
                </div>
                <div class="clients-strip__item item-masotti" aria-hidden="true">
                    <img src="/assets/images/client-masotti.webp" alt="" class="client-logo-img">
                </div>
                <div class="clients-strip__item item-jogoreal" aria-hidden="true">
                    <img src="/assets/images/client-jogoreal.png" alt="" class="client-logo-img">
                </div>
            </div>
        </div>

        <!-- Sobre -->
        <section class="section section--alt bg-sobre" id="sobre" style="position: relative; overflow: hidden; z-index: 1;">
            
            <div class="container" style="position: relative; z-index: 2;">
                <div class="section__header section__header--center">
                    <span class="section__tag fade-in">Quem Somos</span>
                    <h2 class="section__title fade-in">Por que somos únicos?</h2>
                    <p class="section__description fade-in" style="max-width: 800px;">
                        Porque combinamos <strong>método</strong> + <strong>estratégia</strong> + <strong>criatividade</strong>.
                        A Filomena não cria campanhas soltas. Nós <strong>construímos</strong> posicionamento,
                        <strong>fortalecemos</strong> marcas e <strong>direcionamos</strong> cada ação para resultado,
                        performance e conexão real com o público.
                    </p>
                    <a href="sobre" class="btn btn--outline mt-8 fade-in">Conheça nossa história completa</a>
                </div>
            </div>
        </section>

        <!-- Serviços -->
        <section class="section" id="servicos" style="position: relative; overflow: hidden; z-index: 1;">
            
            <div class="container" style="position: relative; z-index: 2;">
                <div class="section__header section__header--center">
                    <span class="section__tag fade-in">O que fazemos</span>
                    <h2 class="section__title fade-in">Nossas frentes<br>de atuação</h2>
                    <p class="section__description fade-in">
                        Da estratégia ao resultado — branding, tráfego pago, campanhas e muito mais.
                    </p>
                </div>

                <div class="services__grid">
                    <article class="service fade-in">
                        <div class="service__number">01</div>
                        <h3 class="service__title">Estratégias de Branding</h3>
                        <p class="service__text">Diagnóstico, posicionamento e construção de comunicação estratégica para marcas que querem crescer.</p>
                                            </article>

                    <article class="service fade-in">
                        <div class="service__number">02</div>
                        <h3 class="service__title">Identidade Visual &amp; Manual de Marca</h3>
                        <p class="service__text">Criamos marcas fortes, consistentes e alinhadas ao posicionamento do seu negócio.</p>
                                            </article>

                    <article class="service fade-in">
                        <div class="service__number">03</div>
                        <h3 class="service__title">Tráfego Pago para Marcas</h3>
                        <p class="service__text">Estratégia, segmentação, otimização e performance com foco em conversão.</p>
                                            </article>

                    <article class="service fade-in">
                        <div class="service__number">04</div>
                        <h3 class="service__title">Campanhas Publicitárias (on e off)</h3>
                        <p class="service__text">Campanhas completas com conceito criativo, mídia, conteúdo e execução.</p>
                                            </article>

                    <article class="service fade-in">
                        <div class="service__number">05</div>
                        <h3 class="service__title">Consultoria Estratégica</h3>
                        <p class="service__text">A visão externa e técnica que o seu negócio precisa para avançar com método e clareza.</p>
                                            </article>

                    <article class="service fade-in">
                        <div class="service__number">06</div>
                        <h3 class="service__title">Conteúdo Orgânico com Estratégia</h3>
                        <p class="service__text">Não é só postar: é construir presença, conexão e posicionamento.</p>
                                            </article>
                </div>

                <div style="text-align: center; margin-top: var(--space-2xl); width: 100%;">
                    <a href="servicos" class="btn btn--primary fade-in" style="font-family: var(--font-heading); padding: 1rem 3rem; font-size: 1.125rem;">Ver todos os serviços</a>
                </div>
            </div>
        </section>

        <!-- Portfólio -->
        <section class="section section--alt" id="portfolio">
            <div class="container">
                <div class="section__header section__header--center">
                    <span class="section__tag fade-in">Trabalhos</span>
                    <h2 class="section__title fade-in">Portfólio</h2>
                    <p class="section__description fade-in" style="max-width: 600px;">
                        Cada projeto é único e pensado estrategicamente para gerar resultados reais.
                    </p>
                </div>

                <div class="portfolio-grid-home fade-in">
                    {featuredProjects.map((project, index) => (
                        <a href="/portfolio" class={`portfolio-grid-home__item ${index === 0 ? 'portfolio-grid-home__item--tall' : (index === 3 ? 'portfolio-grid-home__item--wide' : '')}`}>
                            <img src={project.data.thumbnail} alt={project.data.client} loading="lazy" decoding="async" style={project.id === "dubelato-outdoor" ? "object-fit: contain; background: #ffffff; padding: 8px;" : ""}>
                            <div class="portfolio-grid-home__overlay">
                                <span class="portfolio-grid-home__client">{project.data.client}</span>
                                <span class="portfolio-grid-home__type">{project.data.category}</span>
                            </div>
                        </a>
                    ))}
                </div>

                <div style="text-align: center; margin-top: var(--space-2xl);">
                    <a href="portfolio" class="btn btn--primary fade-in">Ver todos os projetos</a>
                </div>
            </div>
        </section>

        <!-- Cases -->
        <section class="section cases" id="cases">
            <div class="container">
                <div class="section__header section__header--center">
                    <h2 class="cases__title fade-in">Cases</h2>
                </div>

                <div class="cases__grid-new">
                    <!-- Omni -->
                    <div class="case-item fade-in">
                        <h3 class="case-item__title">Omni</h3>
                        <div class="case-item__image">
                            <img src="/assets/images/mockup-omni.png" alt="Omni">
                        </div>
                        <div class="case-item__stats">
                            <div class="case-stat">
                                <span class="case-stat__number">+9</span>
                                <span class="case-stat__label">estados<br>do Brasil</span>
                            </div>
                        </div>
                    </div>

                    <!-- Grampola -->
                    <div class="case-item fade-in">
                        <h3 class="case-item__title">Grampola Peças<br>Automotivas</h3>
                        <div class="case-item__image">
                            <img src="/assets/images/mockup-grampola.png" alt="Grampola Peças Automotivas">
                        </div>
                        <div class="case-item__stats case-item__stats--multi">
                            <div class="case-stat-group">
                                <p class="case-stat-group__title">Google Ads</p>
                                <div class="case-stat-row">
                                    <div class="case-stat case-stat--small">
                                        <span class="case-stat__number">+3.200</span>
                                        <span class="case-stat__label">cliques</span>
                                    </div>
                                    <div class="case-stat case-stat--small">
                                        <span class="case-stat__number">63 mil</span>
                                        <span class="case-stat__label">Impressões</span>
                                    </div>
                                </div>
                            </div>
                            <div class="case-stat-group">
                                <p class="case-stat-group__title">Facebook Ads</p>
                                <div class="case-stat-row">
                                    <div class="case-stat case-stat--small">
                                        <span class="case-stat__number">+1.800</span>
                                        <span class="case-stat__label">cliques</span>
                                    </div>
                                    <div class="case-stat case-stat--small">
                                        <span class="case-stat__number">378 mil</span>
                                        <span class="case-stat__label">Impressões</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- MBA USP -->
                    <div class="case-item fade-in">
                        <h3 class="case-item__title">MBA IA e BigData<br>USP</h3>
                        <div class="case-item__image">
                            <img src="/assets/images/mockup-mba-usp.png" alt="MBA IA e BigData USP">
                        </div>
                        <div class="case-item__stats">
                            <div class="case-stat">
                                <span class="case-stat__number">+2.400</span>
                                <span class="case-stat__label">leads</span>
                            </div>
                            <div class="case-stat">
                                <span class="case-stat__number">+270</span>
                                <span class="case-stat__label">matriculados</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Contato -->
        <section class="section" id="contato">
            <div class="container">
                <div class="contact__grid">
                    <div class="contact__info">
                        <span class="section__tag fade-in">Contato</span>
                        <h2 class="section__title fade-in">Vamos conversar?</h2>
                        <p class="contact__text fade-in">
                            Estamos prontos para ouvir sobre seu projeto e criar algo incrível juntos.
                        </p>

                        <div class="contact__list fade-in">
                            <div class="contact__item">
                                <div class="contact__icon">
                                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                        stroke-width="2">
                                        <path
                                            d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z">
                                        </path>
                                        <polyline points="22,6 12,13 2,6"></polyline>
                                    </svg>
                                </div>
                                <div>
                                    <p class="contact__item-label">E-mail</p>
                                    <a href="mailto:contato@filomenapropaganda.com.br"
                                        class="contact__item-value">contato@filomenapropaganda.com.br</a>
                                </div>
                            </div>

                            <div class="contact__item">
                                <div class="contact__icon">
                                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                        stroke-width="2">
                                        <path
                                            d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.08.64.21 1.27.38 1.88a2 2 0 0 1-.45 2.11L8.09 8.66a16 16 0 0 0 6 6l.95-.95a2 2 0 0 1 2.11-.45c.61.17 1.24.3 1.88.38a2 2 0 0 1 1.72 2v2.28z">
                                        </path>
                                    </svg>
                                </div>
                                <div>
                                    <p class="contact__item-label">Telefone</p>
                                    <a href="tel:+551634154110" class="contact__item-value">(16) 3415-4110</a>
                                </div>
                            </div>

                            <div class="contact__item">
                                <div class="contact__icon">
                                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                        stroke-width="2">
                                        <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                                        <circle cx="12" cy="10" r="3"></circle>
                                    </svg>
                                </div>
                                <div>
                                    <p class="contact__item-label">Endereço</p>
                                    <a href="https://www.google.com/maps/place/Filomena+Propaganda+e+Marketing/@-22.0089776,-47.8877838,17z"
                                        target="_blank" class="contact__item-value">Rua Dom Pedro II, 1978<br>São Carlos
                                        - SP</a>
                                </div>
                            </div>
                        </div>

                        <div class="contact__socials fade-in">
                            <a href="https://www.instagram.com/filomenapropaganda/" target="_blank" class="social-btn"
                                aria-label="Instagram">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                    stroke-width="2">
                                    <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
                                    <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
                                    <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
                                </svg>
                            </a>
                            <a href="https://www.facebook.com/filomenapropaganda" target="_blank" class="social-btn"
                                aria-label="Facebook">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                    stroke-width="2">
                                    <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path>
                                </svg>
                            </a>
                            <a href="https://www.linkedin.com/company/filomena-propaganda/" target="_blank"
                                class="social-btn" aria-label="LinkedIn">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                    stroke-width="2">
                                    <path
                                        d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z">
                                    </path>
                                    <rect x="2" y="9" width="4" height="12"></rect>
                                    <circle cx="4" cy="4" r="2"></circle>
                                </svg>
                            </a>
                            <a href="https://www.behance.net/filomenapropaganda" target="_blank" class="social-btn"
                                aria-label="Behance">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                                    <path
                                        d="M22 7h-7V5h7v2zm1.726 10c-.442 1.297-2.029 3-5.101 3-3.074 0-5.564-1.729-5.564-5.675 0-3.91 2.325-5.92 5.466-5.92 3.082 0 4.964 1.782 5.375 4.426.078.506.109 1.188.095 2.14H15.97c.13 1.949 1.63 2.667 3.25 2.667 1.56 0 2.509-.758 2.905-1.638H24zm-7.02-4h4.045c-.093-1.383-.752-2.132-1.934-2.132-1.221 0-1.934.748-2.111 2.132zM8.691 14.475c0 1.155-.614 1.85-1.912 1.85H3.43v-3.727h3.35c1.284 0 1.911.687 1.911 1.877zM3.43 8.686v3.165H6.5c1.086 0 1.73-.488 1.73-1.548 0-1.064-.644-1.617-1.73-1.617H3.43zM0 6h7.158c1.76 0 3.586 0 4.645 1.288.635.739.984 1.713.984 2.888 0 1.463-.698 2.573-1.985 3.067v.032c1.644.38 2.515 1.577 2.515 3.406 0 2.67-1.969 4.319-5.027 4.319H0V6z" />
                                </svg>
                            </a>
                        </div>

                        <!-- Mapa da Localização -->
                        <div class="contact__map fade-in">
                            <p class="contact__map-label">📍 Nossa localização</p>
                            <div class="contact__map-wrapper">
                                <iframe
                                    src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3699.3241421!2d-47.8877838!3d-22.0089776!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x94b877001cdd3ba5%3A0xe8c0c0c0c0c0c0c0!2sR.%20Dom%20Pedro%20II%2C%201978%20-%20Centro%2C%20S%C3%A3o%20Carlos%20-%20SP!5e0!3m2!1spt-BR!2sbr!4v1703782800000!5m2!1spt-BR!2sbr"
                                    width="100%" height="200" style="border:0; border-radius: 12px;" allowfullscreen=""
                                    loading="lazy" referrerpolicy="no-referrer-when-downgrade">
                                </iframe>
                            </div>
                            <a href="https://www.google.com/maps/dir//Filomena+Propaganda+e+Marketing/@-22.0089776,-47.8877838,17z"
                                target="_blank" class="btn btn--outline btn--sm contact__map-btn">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                    stroke-width="2">
                                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                                    <circle cx="12" cy="10" r="3"></circle>
                                </svg>
                                Ver rotas no Google Maps
                            </a>
                        </div>
                    </div>

                    <form class="contact__form fade-in">
                        <div class="form-group">
                            <label for="name">Nome</label>
                            <input type="text" id="name" name="name" required>
                        </div>
                        <div class="form-group">
                            <label for="email">E-mail</label>
                            <input type="email" id="email" name="email" required>
                        </div>
                        <div class="form-group">
                            <label for="phone">WhatsApp</label>
                            <input type="tel" id="phone" name="phone">
                        </div>
                        <div class="form-group">
                            <label for="message">Mensagem</label>
                            <textarea id="message" name="message" rows="4" required></textarea>
                        </div>
                        <button type="submit" class="btn btn--primary btn--full">Enviar mensagem</button>
                    </form>
                </div>
            </div>
        </section>

        <!-- Instagram Feed -->
        <section class="section instagram-section">
            <div class="container">
                <div class="section__header section__header--center">
                    <span class="section__tag fade-in">Siga-nos</span>
                    <h2 class="section__title fade-in">@filomenapropaganda</h2>
                    <p class="section__description fade-in">Acompanhe nosso dia a dia e trabalhos nas redes sociais</p>
                </div>

                <div class="instagram-embeds">
                    <blockquote class="instagram-media" data-instgrm-captioned
                        data-instgrm-permalink="https://www.instagram.com/p/DQFc00sDWcm/" data-instgrm-version="14">
                    </blockquote>
                    <blockquote class="instagram-media" data-instgrm-captioned
                        data-instgrm-permalink="https://www.instagram.com/p/DJmNoIJMdqF/" data-instgrm-version="14">
                    </blockquote>
                    <blockquote class="instagram-media" data-instgrm-captioned
                        data-instgrm-permalink="https://www.instagram.com/p/DMaQdvlMmG-/" data-instgrm-version="14">
                    </blockquote>
                    <blockquote class="instagram-media" data-instgrm-captioned
