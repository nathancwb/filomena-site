---
import { getCollection } from 'astro:content';
const posts = await getCollection('blog');
---
<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Blog da Filomena Propaganda - Insights, tendências e estratégias de marketing e comunicação.">
    <title>Blog | Filomena Propaganda</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/styles.css">

    <style>
        .blog-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: var(--space-xl);
            margin-top: var(--space-4xl);
        }
        @media (max-width: 968px) { .blog-grid { grid-template-columns: repeat(2, 1fr); } }
        @media (max-width: 576px) { .blog-grid { grid-template-columns: 1fr; } }

        .blog-card {
            background: var(--bg);
            border: 1px solid var(--border);
            border-radius: 20px;
            overflow: hidden;
            transition: all var(--transition);
        }
        .blog-card:hover {
            border-color: var(--accent);
            transform: translateY(-6px);
            box-shadow: var(--shadow-lg);
        }
        .blog-card__img {
            width: 100%;
            height: 200px;
            object-fit: cover;
            background: var(--bg-alt);
        }
        .blog-card__body { padding: var(--space-xl); }
        .blog-card__tag {
            font-size: var(--text-xs);
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: var(--accent);
            margin-bottom: var(--space-sm);
            display: block;
        }
        .blog-card__title {
            font-family: var(--font-heading);
            font-size: var(--text-xl);
            font-weight: 700;
            margin-bottom: var(--space-md);
            line-height: 1.3;
        }
        .blog-card__excerpt {
            font-size: var(--text-sm);
            color: var(--text-muted);
            margin-bottom: var(--space-lg);
            line-height: 1.6;
        }
        .blog-card__link {
            display: inline-flex;
            align-items: center;
            gap: var(--space-xs);
            font-size: var(--text-sm);
            font-weight: 600;
            color: var(--accent);
        }
    </style>
</head>

<body>
    <div class="noise-overlay"></div>
    <!-- Header -->
    <header class="header">
        <div class="header__inner container">
            <a href="/" class="logo">
                <img src="/assets/images/logo-main.png" alt="Filomena Propaganda & Marketing" class="logo__img">
            </a>

            <nav class="nav">
                <ul class="nav__list" id="nav-menu">
                    <li><a href="/" class="nav__link">Home</a></li>
                    <li><a href="sobre" class="nav__link">Sobre</a></li>
                    <li><a href="servicos" class="nav__link">Serviços</a></li>
                    <li><a href="portfolio" class="nav__link">Portfólio</a></li>
                    <li><a href="blog" class="nav__link">Blog</a></li>
                    <li><a href="trabalhe-conosco" class="nav__link">Trabalhe Conosco</a></li>
                    <li><a href="contato" class="nav__link">Contato</a></li>
                </ul>

                <div class="nav__actions">
                    <button class="menu-toggle" id="menu-toggle" aria-label="Menu">
                        <span></span><span></span><span></span>
                    </button>
                </div>
            </nav>
        </div>
    </header>

    <main>
        <!-- Page Hero -->
        <section class="page-hero">
            <div class="container">
                <span class="section__tag fade-in">Conteúdo</span>
                <h1 class="page-hero__title fade-in">Blog</h1>
                <p class="page-hero__description fade-in">
                    Insights, tendências e estratégias para marcas que querem crescer de verdade.
                </p>
            </div>
        </section>

        <!-- Blog Grid -->
        <section class="section">
            <div class="container">
                <div class="blog-grid">
                    {posts.map(post => (
                        <article class="blog-card fade-in">
                            <img src={post.data.thumbnail || "/assets/images/fachada-filomena.png"} alt={post.data.category} class="blog-card__img" style="object-fit: cover;">
                            <div class="blog-card__body">
                                <span class="blog-card__tag">{post.data.category}</span>
                                <h2 class="blog-card__title">{post.data.title}</h2>
                                <p class="blog-card__excerpt">{post.data.description}</p>
                                <a href={`/blog/${post.id}`} class="blog-card__link">
                                    Ler artigo
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"></path></svg>
                                </a>
                            </div>
                        </article>
                    ))}
                </div>
            </div>
        </section>
    </main>

    <!-- Footer -->
    <footer class="footer">
        <div class="container">
            <div class="footer__grid">
                <div class="footer__brand">
                    <a href="/" class="logo logo--footer">
                        <img src="/assets/images/footer-logo.png" alt="Filomena Propaganda & Marketing" class="logo__img">
                    </a>
                    <p>Comunicação criativa que conecta.</p>
                    <span class="footer__tagline">#teamfilomena</span>
                
                    <div class="footer__socials" style="display: flex; gap: var(--space-xs); margin-top: var(--space-md);">
                        <a href="https://www.instagram.com/filomenapropaganda/" target="_blank" class="social-btn" aria-label="Instagram">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
                        </a>
                        <a href="https://www.facebook.com/filomenapropaganda" target="_blank" class="social-btn" aria-label="Facebook">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
                        </a>
                        <a href="https://www.linkedin.com/company/filomena-propaganda/" target="_blank" class="social-btn" aria-label="LinkedIn">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg>
                        </a>
                        <a href="https://www.behance.net/filomenapropaganda" target="_blank" class="social-btn" aria-label="Behance">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M22 7h-7V5h7v2zm1.726 10c-.442 1.297-2.029 3-5.101 3-3.074 0-5.564-1.729-5.564-5.675 0-3.91 2.325-5.92 5.466-5.92 3.082 0 4.964 1.782 5.375 4.426.078.506.109 1.188.095 2.14H15.97c.13 1.949 1.63 2.667 3.25 2.667 1.56 0 2.509-.758 2.905-1.638H24zm-7.02-4h4.045c-.093-1.383-.752-2.132-1.934-2.132-1.221 0-1.934.748-2.111 2.132zM8.691 14.475c0 1.155-.614 1.85-1.912 1.85H3.43v-3.727h3.35c1.284 0 1.911.687 1.911 1.877zM3.43 8.686v3.165H6.5c1.086 0 1.73-.488 1.73-1.548 0-1.064-.644-1.617-1.73-1.617H3.43zM0 6h7.158c1.76 0 3.586 0 4.645 1.288.635.739.984 1.713.984 2.888 0 1.463-.698 2.573-1.985 3.067v.032c1.644.38 2.515 1.577 2.515 3.406 0 2.67-1.969 4.319-5.027 4.319H0V6z"/></svg>
                        </a>
                    </div></div>
                <div>
                    <h4 class="footer__title">Navegação</h4>
                    <ul class="footer__links">
                        <li><a href="/">Home</a></li>
                        <li><a href="sobre">Sobre nós</a></li>
                        <li><a href="servicos">Serviços</a></li>
                        <li><a href="portfolio">Portfólio</a></li>
                        <li><a href="blog">Blog</a></li>
                        <li><a href="trabalhe-conosco">Trabalhe Conosco</a></li>
                        <li><a href="contato">Contato</a></li>
                    </ul>
                </div>
                <div>
                    <h4 class="footer__title">Serviços</h4>
                    <ul class="footer__links">
                        <li><a href="servicos#branding">Branding</a></li>
                        <li><a href="servicos#marketing">Marketing Digital</a></li>
                        <li><a href="servicos#audiovisual">Audiovisual</a></li>
                        <li><a href="servicos#midia">Mídia</a></li>
                    </ul>
                </div>
                <div>
                    <h4 class="footer__title">Trabalhe Conosco</h4>
                    <p style="margin-bottom: var(--space-md);">Quer fazer parte do time?</p>
                    <a href="trabalhe-conosco" class="btn btn--outline" style="border-color: var(--gray-600); color: var(--white);">Enviar currículo</a>
                </div>
            </div>

            <div class="footer__bottom">
                <p>© 2025 Filomena Propaganda. Todos os direitos reservados.</p>
                <p>São Carlos - SP</p>
            </div>
        </div>
    </footer>

    <a href="https://api.whatsapp.com/send?l=pt_BR&phone=551634154110" class="whatsapp-btn" target="_blank" aria-label="WhatsApp">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
    </a>

    <script src="/script.js" is:inline></script>
</body>

</html>
