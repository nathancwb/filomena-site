<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Trabalhe na Filomena Propaganda - Faça parte de uma equipe criativa, estratégica e apaixonada por comunicação. São Carlos-SP.">
    <title>Trabalhe Conosco | Filomena Propaganda</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/styles.css">

    <style>
        .jobs-form {
            max-width: 700px;
            margin: 0 auto;
        }
        .form-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: var(--space-lg);
        }
        @media (max-width: 576px) { .form-row { grid-template-columns: 1fr; } }

        .upload-area {
            width: 100%;
            padding: 20px 24px;
            border: 2px dashed var(--border);
            border-radius: 12px;
            background: var(--bg-alt);
            display: flex;
            align-items: center;
            gap: var(--space-md);
            cursor: pointer;
            transition: border-color var(--transition);
            font-size: var(--text-sm);
            color: var(--text-muted);
        }
        .upload-area:hover { border-color: var(--accent); }
        .upload-area input[type="file"] { display: none; }

        .perks-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: var(--space-lg);
            margin-top: var(--space-3xl);
        }
        @media (max-width: 576px) { .perks-grid { grid-template-columns: 1fr; } }

        .perk {
            display: flex;
            align-items: flex-start;
            gap: var(--space-md);
            padding: var(--space-xl);
            background: var(--bg-alt);
            border-radius: 16px;
            border: 1px solid var(--border);
        }
        .perk__icon {
            width: 44px;
            height: 44px;
            flex-shrink: 0;
            background: var(--accent);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
        }
        .perk__title {
            font-family: var(--font-heading);
            font-size: var(--text-base);
            font-weight: 600;
            margin-bottom: 4px;
        }
        .perk__text { font-size: var(--text-sm); color: var(--text-muted); }
    </style>
</head>

<body>
    <div class="noise-overlay"></div>
    <!-- Header -->
    <header class="header">
        <div class="header__inner container">
            <a href="/" class="logo">
                <img src="/assets/images/logo-main.png" alt="Filomena Propaganda & Marketing" class="logo__img">
            </a>

            <nav class="nav">
                <ul class="nav__list" id="nav-menu">
                    <li><a href="/" class="nav__link">Home</a></li>
                    <li><a href="sobre" class="nav__link">Sobre</a></li>
                    <li><a href="servicos" class="nav__link">Serviços</a></li>
                    <li><a href="portfolio" class="nav__link">Portfólio</a></li>
                    <li><a href="blog" class="nav__link">Blog</a></li>
                    <li><a href="trabalhe-conosco" class="nav__link">Trabalhe Conosco</a></li>
                    <li><a href="contato" class="nav__link">Contato</a></li>
                </ul>

                <div class="nav__actions">
                    <button class="menu-toggle" id="menu-toggle" aria-label="Menu">
                        <span></span><span></span><span></span>
                    </button>
                </div>
            </nav>
        </div>
    </header>

    <main>
        <!-- Page Hero -->
        <section class="page-hero">
            <div class="container">
                <span class="section__tag fade-in">Carreiras</span>
                <h1 class="page-hero__title fade-in">Faça parte do<br>nosso time</h1>
                <p class="page-hero__description fade-in">
                    Estamos sempre conectados a profissionais criativos, estratégicos e apaixonados por comunicação.
                </p>
            </div>
        </section>

        <!-- Why Filomena -->
        <section class="section section--alt">
            <div class="container">
                <div class="section__header section__header--center">
                    <span class="section__tag fade-in">Por que trabalhar aqui</span>
                    <h2 class="section__title fade-in">Um lugar para quem ama o que faz</h2>
                    <p class="section__description fade-in">
                        Na Filomena, acreditamos que trabalho bom se traduz com cliente feliz. Pensamos e agimos como donos, inovar é divertido e o respeito por todos é inegociável.
                    </p>
                </div>
                <div class="perks-grid">
                    <div class="perk fade-in">
                        <div class="perk__icon">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                                <circle cx="9" cy="7" r="4"></circle>
                                <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                                <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                            </svg>
                        </div>
                        <div>
                            <p class="perk__title">Ambiente colaborativo</p>
                            <p class="perk__text">Uma equipe que se ajuda, compartilha conhecimento e celebra junto cada conquista.</p>
                        </div>
                    </div>
                    <div class="perk fade-in">
                        <div class="perk__icon">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
                            </svg>
                        </div>
                        <div>
                            <p class="perk__title">Projetos desafiadores</p>
                            <p class="perk__text">Trabalhe com marcas reais, campanhas criativas e cases que constroem portfólio.</p>
                        </div>
                    </div>
                    <div class="perk fade-in">
                        <div class="perk__icon">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <polyline points="23 6 13.5 15.5 8.5 10.5 1 18"></polyline>
                                <polyline points="17 6 23 6 23 12"></polyline>
                            </svg>
                        </div>
                        <div>
                            <p class="perk__title">Desenvolvimento profissional</p>
                            <p class="perk__text">Crescimento contínuo em um mercado que se reinventa o tempo todo.</p>
                        </div>
                    </div>
                    <div class="perk fade-in">
                        <div class="perk__icon">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
                            </svg>
                        </div>
                        <div>
                            <p class="perk__title">Equipe apaixonada</p>
                            <p class="perk__text">Somos o #teamfilomena — pessoas que fazem comunicação com propósito e paixão.</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Form -->
        <section class="section">
            <div class="container">
                <div class="section__header section__header--center">
                    <span class="section__tag fade-in">Candidate-se</span>
                    <h2 class="section__title fade-in">Envie seu currículo</h2>
                    <p class="section__description fade-in">
                        Mesmo sem vagas abertas, estamos sempre em busca de novos talentos.
                    </p>
                </div>

                <form class="contact__form jobs-form fade-in" style="margin-top: var(--space-3xl);">
                    <div class="form-group">
                        <label for="nome">Nome completo</label>
                        <input type="text" id="nome" name="nome" placeholder="Digite seu nome completo" required>
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label for="email">E-mail</label>
                            <input type="email" id="email" name="email" placeholder="Seu e-mail" required>
                        </div>
                        <div class="form-group">
                            <label for="telefone">Telefone/WhatsApp</label>
                            <input type="tel" id="telefone" name="telefone" placeholder="Seu telefone">
                        </div>
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label for="area">Área de atuação</label>
                            <input type="text" id="area" name="area" placeholder="Sua área de atuação">
                        </div>
                        <div class="form-group">
                            <label for="portfolio">Link do portfólio</label>
                            <input type="url" id="portfolio" name="portfolio" placeholder="Link do portfólio ou LinkedIn">
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Currículo ou portfólio</label>
                        <label class="upload-area" for="arquivo">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                                <polyline points="17 8 12 3 7 8"></polyline>
                                <line x1="12" y1="3" x2="12" y2="15"></line>
                            </svg>
                            Adicione seu currículo ou portfólio
                            <input type="file" id="arquivo" name="arquivo" accept=".pdf,.doc,.docx">
                        </label>
                    </div>
                    <button type="submit" class="btn btn--primary btn--full">Enviar candidatura →</button>
                </form>
            </div>
        </section>
    </main>

    <!-- Footer -->
    <footer class="footer">
        <div class="container">
            <div class="footer__grid">
                <div class="footer__brand">
                    <a href="/" class="logo logo--footer">
                        <img src="/assets/images/footer-logo.png" alt="Filomena Propaganda & Marketing" class="logo__img">
                    </a>
                    <p>Comunicação criativa que conecta.</p>
                    <span class="footer__tagline">#teamfilomena</span>
                </div>
                <div>
                    <h4 class="footer__title">Navegação</h4>
                    <ul class="footer__links">
                        <li><a href="/">Home</a></li>
                        <li><a href="sobre">Sobre nós</a></li>
                        <li><a href="servicos">Serviços</a></li>
                        <li><a href="portfolio">Portfólio</a></li>
                        <li><a href="blog">Blog</a></li>
                        <li><a href="trabalhe-conosco">Trabalhe Conosco</a></li>
                        <li><a href="contato">Contato</a></li>
                    </ul>
                </div>
                <div>
                    <h4 class="footer__title">Contato</h4>
                    <ul class="footer__links">
                        <li><a href="tel:+551634154110">(16) 3415-4110</a></li>
                        <li><a href="mailto:contato@filomenapropaganda.com.br">contato@filomenapropaganda.com.br</a></li>
                        <li>R. Dom Pedro II, 1978<br>São Carlos - SP, 13560-235</li>
                    </ul>
                </div>
                <div>
                    <h4 class="footer__title">Endereço</h4>
                    <p style="color: var(--text-muted); font-size: var(--text-sm); line-height: 1.7;">
                        R. Dom Pedro II, 1978<br>
                        Jardim Macarengo<br>
                        São Carlos - SP, 13560-235
                    </p>
                </div>
            </div>
            <div class="footer__bottom">
                <p>© 2025 Filomena Propaganda. Todos os direitos reservados.</p>
                <p>São Carlos - SP</p>
            </div>
        </div>
    </footer>

    <a href="https://api.whatsapp.com/send?l=pt_BR&phone=551634154110" class="whatsapp-btn" target="_blank" aria-label="WhatsApp">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
