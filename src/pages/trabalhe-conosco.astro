        .upload-area {
            width: 100%;
            padding: 20px 24px;
            border: 2px dashed var(--border);
            border-radius: 12px;
            background: var(--bg-alt);
            display: flex;
            align-items: center;
            gap: var(--space-md);
            cursor: pointer;
            transition: border-color var(--transition);
            font-size: var(--text-sm);
            color: var(--text-muted);
        }
        .upload-area:hover { border-color: var(--accent); }
        .upload-area input[type="file"] { display: none; }

        .perks-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: var(--space-lg);
            margin-top: var(--space-3xl);
        }
        @media (max-width: 576px) { .perks-grid { grid-template-columns: 1fr; } }

        .perk {
            display: flex;
            align-items: flex-start;
            gap: var(--space-md);
            padding: var(--space-xl);
            background: var(--bg-alt);
            border-radius: 16px;
            border: 1px solid var(--border);
        }
        .perk__icon {
            width: 44px;
            height: 44px;
            flex-shrink: 0;
            background: var(--accent);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
        }
        .perk__title {
            font-family: var(--font-heading);
            font-size: var(--text-base);
            font-weight: 600;
            margin-bottom: 4px;
        }
        .perk__text { font-size: var(--text-sm); color: var(--text-muted); }
