---
import { getEntry } from 'astro:content';
const sobrePage = await getEntry('pages', 'sobre');
---
<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description"
        content="Conheça a história da Filomena Gestão de Marcas — agência de publicidade criada em 2013 em São Carlos-SP, com mais de 250 marcas atendidas em todo o Brasil.">
    <title>Sobre Nós | Filomena Gestão de Marcas</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/styles.css">

    <style>
        /* =========================================
           SOBRE PAGE — PREMIUM REDESIGN
        ========================================= */

        /* --- Por que Filomena? (Hero section roxa) --- */
        .sobre-hero {
            background: #3a0f38;
            color: white;
            padding: 7rem 0 5rem;
            position: relative;
            overflow: hidden;
        }

        .sobre-hero::before {
            content: '';
            position: absolute;
            inset: 0;
            background: radial-gradient(ellipse at 70% 50%, rgba(106,34,99,0.6) 0%, transparent 65%);
            pointer-events: none;
        }

        /* Bird mascot background — inline SVG */
        .sobre-hero__bird-svg {
            position: absolute;
            right: -80px;
            bottom: -60px;
            width: 500px;
            height: 500px;
            opacity: 0.2;
            pointer-events: none;
            z-index: 0;
        }

        .sobre-hero__inner {
            display: grid;
            grid-template-columns: 1fr 480px;
            gap: 5rem;
            align-items: center;
            position: relative;
            z-index: 1;
        }

        .sobre-hero__tag {
            display: inline-block;
            font-size: 0.75rem;
            font-weight: 700;
            letter-spacing: 0.18em;
            text-transform: uppercase;
            color: rgba(255,255,255,0.55);
            margin-bottom: 1.5rem;
        }

        .sobre-hero__title {
            font-size: clamp(2.8rem, 6vw, 5rem);
            font-weight: 900;
            color: white;
            line-height: 1.05;
            margin-bottom: 2rem;
        }

        .sobre-hero__text {
            font-size: 1.1rem;
            line-height: 1.85;
            color: rgba(255,255,255,0.78);
            margin-bottom: 1.25rem;
        }

        .sobre-hero__text strong {
            color: white;
            font-weight: 700;
        }

        .sobre-hero__logo-side {
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .sobre-hero__logo-side img {
            width: 100%;
            max-width: 400px;
            opacity: 0.9;
            filter: brightness(0) invert(1);
        }

        /* --- Nossa História + Stats --- */
        .historia-section {
            padding: 7rem 0;
        }

        .historia-grid {
            display: grid;
            grid-template-columns: 1fr 340px;
            gap: 5rem;
            align-items: start;
        }

        @keyframes statsAppear {
            from { opacity: 0; transform: translateY(20px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        .stats-stack {
            animation: statsAppear 0.7s ease 0.25s both;
        }

        .historia-title {
            font-size: clamp(2rem, 4vw, 3.2rem);
            font-weight: 900;
            margin-bottom: 1.75rem;
            line-height: 1.1;
        }

        .historia-text {
            font-size: 1.1rem;
            line-height: 1.85;
            color: var(--text-muted);
            margin-bottom: 1.25rem;
        }

        /* Stats cards */
        .stats-stack {
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }

        .stat-card {
            background: var(--primary, #6b2d8b);
            color: #ffffff;
            border-radius: 16px;
            padding: 2rem 2.25rem;
            position: relative;
            overflow: hidden;
        }

        .stat-card::before {
            content: '';
            position: absolute;
            top: -40%;
            right: -20%;
            width: 160px;
            height: 160px;
            border-radius: 50%;
            background: rgba(255,255,255,0.07);
        }

        .stat-card--center {
            text-align: center;
        }

        .stat-number {
            font-size: 3.5rem;
            font-weight: 900;
            font-style: italic;
            line-height: 1;
            display: block;
            color: #ffffff;
        }

        .stat-label {
            font-size: 0.95rem;
            font-style: italic;
            opacity: 0.88;
            margin-top: 0.35rem;
            display: block;
        }

        .stat-card--brasil {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
        }

        .stat-card--brasil .stat-label {
            font-size: 1.05rem;
            font-style: normal;
            font-weight: 700;
            line-height: 1.35;
        }

        /* Brazil silhouette */
        .brasil-icon {
            width: 72px;
            height: 72px;
            flex-shrink: 0;
            opacity: 0.4;
        }

        /* --- Cultura Filomena — Premium redesign --- */
        .cultura-section {
            background: #3a0f38;
            padding: 7rem 0;
            position: relative;
            overflow: hidden;
        }

        .cultura-section::before {
            content: '';
            position: absolute;
            inset: 0;
            background: radial-gradient(ellipse at 30% 100%, rgba(106,34,99,0.5) 0%, transparent 65%);
            pointer-events: none;
        }

        .cultura-header {
            text-align: center;
            margin-bottom: 5rem;
            position: relative;
            z-index: 1;
        }

        .cultura-tag {
            display: inline-block;
            font-size: 0.75rem;
            font-weight: 700;
            letter-spacing: 0.18em;
            text-transform: uppercase;
            color: rgba(255,255,255,0.5);
            margin-bottom: 1rem;
        }

        .cultura-title {
            font-size: clamp(2.2rem, 5vw, 4rem);
            font-weight: 900;
            color: white;
        }

        .cultura-cards {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 1.5rem;
            position: relative;
            z-index: 1;
        }

        .cultura-card {
            background: rgba(255,255,255,0.06);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 20px;
            padding: 2.5rem;
            transition: background 0.3s ease, transform 0.3s ease;
            backdrop-filter: blur(8px);
        }

        .cultura-card:hover {
            background: rgba(255,255,255,0.1);
            transform: translateY(-4px);
        }

        .cultura-card__number {
            font-size: 4.5rem;
            font-weight: 900;
            font-style: italic;
            color: rgba(255,255,255,0.12);
            line-height: 1;
            margin-bottom: 1.25rem;
            display: block;
        }

        .cultura-card__title {
            font-size: 1.4rem;
            font-weight: 800;
            color: white;
            margin-bottom: 1rem;
        }

        .cultura-card__text {
            font-size: 0.95rem;
            line-height: 1.75;
            color: rgba(255,255,255,0.7);
        }

        .cultura-card__tags {
            display: flex;
            flex-wrap: wrap;
            gap: 0.5rem;
            margin-top: 1.5rem;
        }

        .cultura-tag-pill {
            font-size: 0.8rem;
            font-weight: 600;
            padding: 0.35rem 0.9rem;
            border-radius: 999px;
            background: rgba(255,255,255,0.12);
            color: rgba(255,255,255,0.85);
            border: 1px solid rgba(255,255,255,0.15);
        }

        /* --- Cases de Sucesso --- */
        .cases-section {
            padding: 7rem 0;
        }

        .cases-header {
            margin-bottom: 3.5rem;
        }

        .cases-title {
            font-size: clamp(2rem, 5vw, 3.5rem);
            font-weight: 900;
            margin-bottom: 1rem;
        }

        .cases-desc {
            font-size: 1.1rem;
            color: var(--text-muted);
            max-width: 560px;
            line-height: 1.7;
        }

        .cases-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 2rem;
        }

        .case-item {
            position: relative;
            border-radius: 16px;
            overflow: hidden;
            aspect-ratio: 4/3;
            cursor: pointer;
            text-decoration: none;
            display: block;
        }

        .case-item img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
        }

        .case-item:hover img {
            transform: scale(1.06);
        }

        .case-item__overlay {
            position: absolute;
            inset: 0;
            background: linear-gradient(to top, rgba(0,0,0,0.75) 0%, transparent 50%);
            display: flex;
            flex-direction: column;
            justify-content: flex-end;
            padding: 1.75rem;
            opacity: 0;
            transition: opacity 0.3s ease;
        }

        .case-item:hover .case-item__overlay {
            opacity: 1;
        }

        /* Always visible labels at bottom */
        .case-item__label {
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            padding: 1.25rem 1.5rem 1.25rem;
            background: linear-gradient(to top, rgba(0,0,0,0.72) 0%, transparent 100%);
        }

        .case-item__name {
            font-size: 1rem;
            font-weight: 700;
            color: white;
            line-height: 1.3;
        }

        .case-item__tag {
            font-size: 0.78rem;
            color: rgba(255,255,255,0.65);
            margin-top: 0.2rem;
        }

        /* Responsive */
        @media (max-width: 900px) {
            .sobre-hero__inner { grid-template-columns: 1fr; }
            .sobre-hero__logo-side { display: none; }
            .historia-grid { grid-template-columns: 1fr; }
            .cultura-cards { grid-template-columns: 1fr; }
            .cases-grid { grid-template-columns: 1fr; }
        }
    </style>
</head>

<body>
    <div class="noise-overlay"></div>

    <!-- Header -->
    <header class="header">
        <div class="header__inner container">
            <a href="/" class="logo">
                <img src="/assets/images/logo-main.png" alt="Filomena Propaganda & Marketing" class="logo__img">
            </a>
            <nav class="nav">
                <ul class="nav__list" id="nav-menu">
                    <li><a href="/" class="nav__link">Home</a></li>
                    <li><a href="sobre" class="nav__link active">Sobre</a></li>
                    <li><a href="servicos" class="nav__link">Serviços</a></li>
                    <li><a href="portfolio" class="nav__link">Portfólio</a></li>
                    <li><a href="blog" class="nav__link">Blog</a></li>
                    <li><a href="trabalhe-conosco" class="nav__link">Trabalhe Conosco</a></li>
                    <li><a href="contato" class="nav__link">Contato</a></li>
                </ul>
                <div class="nav__actions">
                    <button class="menu-toggle" id="menu-toggle" aria-label="Menu">
                        <span></span><span></span><span></span>
                    </button>
                </div>
            </nav>
        </div>
    </header>

    <main>

        <!-- =========================================
             HERO — Por que "Filomena"?
        ========================================= -->
        <section class="sobre-hero">
            <!-- Pássaro decorativo inline (sem dependência de request externo) -->
            <svg class="sobre-hero__bird-svg" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1000 1000">
              <defs><style>.cls-bird { fill: rgba(255,255,255,0.9); stroke-width: 0px; }</style></defs>
              <path class="cls-bird" d="M830.11,258.91c-41.12-33.7-47.98-53.12-47.98-53.12-79.39-55.4-155.93,0-155.93,0-61.69,9.71-90.25,29.7-90.25,29.7,39.41,5.14,76.54,27.42,76.54,27.42,61.79,39.73,43.41,79.96,43.41,79.96-130.23,55.98-279.88,199.91-292.73,230.76-12.85,30.84-52.26,49.69-52.26,49.69,0,0-182.49,83.96-253.6,157.65-71.11,73.68,21.42,17.14,21.42,17.14-17.99,48.84,44.55-6.85,44.55-6.85-15.42,28.27-6,43.7,40.27-6.4,46.27-50.09,191.92-107.27,191.92-107.27,53.69,5.71,86.82-9.14,86.82-9.14,58.26,17.14,75.4,49.69,75.4,49.69-.57,23.42,20.56,22.28,20.56,22.28l64.54,44.44c.36,2.96,1.4,6.02,2.81,8.99h-240.87c-6.9,0-12.5,5.59-12.5,12.5h0c0,6.9,5.59,12.5,12.5,12.5h592.35c6.9,0,12.5-5.59,12.5-12.5h0c0-6.9-5.59-12.5-12.5-12.5h-102.07l30-17.32c5.98-3.45,8.02-11.09,4.57-17.07h0c-3.45-5.98-11.09-8.02-17.07-4.57l-67.48,38.96h-152.17c-6.84-17.12-25.51-24.87-25.51-24.87-29.13-21.7-58.55-54.83-58.55-54.83,0,0,222.76-33.41,304.15-179.06,81.39-145.65-1.71-242.47-42.84-276.16ZM552.51,231.55s28.3-15.8,66.81-17.77c0,0-20.08,9.22-66.81,17.77ZM873.59,759.78c-19.42,18.43-48.71,27.65-48.71,27.65,22.38-15.47,48.71-27.65,48.71-27.65ZM956.73,798.29c-62.53,9.22-295.28,0-295.28,0,52-2.96,295.28,0,295.28,0ZM622.94,769.41s-28.14-8.39-48.38-41.72c0,0,21.01,22.39,48.38,41.72ZM633.14,362.54c-79.65,48.71-164.24,121.11-164.24,121.11,72.72-80.3,164.24-121.11,164.24-121.11ZM126.31,796.97s78.99-92.81,224.46-168.51c0,0-103.34,56.61-224.46,168.51ZM83.52,796.97s86.23-94.13,282.38-182.99c0,0-136.91,65.16-282.38,182.99ZM66.41,782.49s79.65-84.91,312.66-182.33c0,0-173.77,81.62-312.66,182.33ZM370.28,584.04c-.06,0-.1,0-.1,0,.03,0,.07,0,.1,0,5.76.2,285.43,9.06,304-163.9,0,0,44.42,177.69-304,163.9ZM653.55,396.44c32.58-57.27,13.82-97.75,13.82-97.75,33.08,49.86-13.82,97.75-13.82,97.75ZM687.61,234.02c-7.36,0-13.33-5.97-13.33-13.33s5.97-13.33,13.33-13.33,13.33,5.97,13.33,13.33-5.97,13.33-13.33,13.33ZM678.23,188.77s46.73-9.87,85.57,14.48c0,0-35.87-13.49-85.57-14.48ZM849.04,557.38s83.92-139.22-7.9-269.54c0,0,117.49,103.67,7.9,269.54Z"/>
            </svg>

            <div class="container">
                <div class="sobre-hero__inner">
                    <div class="sobre-hero__content fade-in">
                        <span class="sobre-hero__tag">Nossa História</span>
                        <h1 class="sobre-hero__title">Por que<br>"Filomena"?</h1>
                        <p class="sobre-hero__text">
                            O nome foi inspirado na personagem da mitologia grega. Filomena foi aprisionada e teve sua
                            língua cortada para não se comunicar. Na prisão ela teceu um tapete para contar o que havia
                            acontecido e onde estava. O tapete chegou até sua família, que a libertou do cativeiro.
                        </p>
                        <p class="sobre-hero__text">
                            Apesar disso, ela continuou sendo perseguida e, para ser livre, pediu ajuda aos deuses que a
                            transforou em um pássaro rouxinol. Esse é o desafio diário da equipe da Filomena Propaganda:
                            <strong>uma comunicação que se recria frente ao dinamismo dos meios, principalmente o digital.</strong>
                        </p>
                    </div>
                    <div class="sobre-hero__logo-side fade-in">
                        <img src="/assets/images/footer-logo.png" alt="Filomena Gestão de Marcas">
                    </div>
                </div>
            </div>
        </section>

        <!-- =========================================
             NOSSA HISTÓRIA + STATS
        ========================================= -->
        <section class="historia-section">
            <div class="container">
                <div class="historia-grid">
                    <div class="fade-in">
                        <h2 class="historia-title">Nossa história<br>até aqui</h2>
                        <p class="historia-text">
                            A Filomena Gestão de Marcas é uma agência de publicidade criada em julho de 2013 e hoje
                            orgulha-se de ter atendido mais de 250 empresas dos setores da indústria, varejo e serviço.
                        </p>
                        <p class="historia-text">
                            A agência está localizada em São Carlos e atende clientes em todo território nacional.
                        </p>
                    </div>

                    <div class="stats-stack">
                        <div class="stat-card stat-card--center">
                            <span class="stat-number">{sobrePage.data.stats_marcas || '+250'}</span>
                            <span class="stat-label">Marcas atendidas</span>
                        </div>
                        <div class="stat-card stat-card--center">
                            <span class="stat-number">{sobrePage.data.stats_anos || '13'}</span>
                            <span class="stat-label">Anos voando alto</span>
                        </div>
                        <div class="stat-card stat-card--center">
                            <span class="stat-number">{sobrePage.data.alcance || 'Nacional'}</span>
                            <span class="stat-label">Clientes em todo o Brasil</span>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- =========================================
             A CULTURA FILOMENA — Premium redesign
        ========================================= -->
        <section class="cultura-section">
            <div class="container">
                <div class="cultura-header fade-in">
                    <span class="cultura-tag">Nossa Bússola</span>
                    <h2 class="cultura-title">A Cultura Filomena</h2>
                </div>

                <div class="cultura-cards">
                    <div class="cultura-card fade-in">
                        <span class="cultura-card__number">01</span>
                        <h3 class="cultura-card__title">Missão</h3>
                        <p class="cultura-card__text">
                            {sobrePage.data.cultura_missao || 'Oferecer as melhores soluções integradas de comunicação e mídia para empresas que entendam a importância do marketing.'}
                        </p>
                    </div>

                    <div class="cultura-card fade-in">
                        <span class="cultura-card__number">02</span>
                        <h3 class="cultura-card__title">Visão</h3>
                        <p class="cultura-card__text">
                            {sobrePage.data.cultura_visao || 'Ser uma agência ágil, acessível e criativa, referência na solução de problemas no interior de SP.'}
                        </p>
                    </div>

                    <div class="cultura-card fade-in">
                        <span class="cultura-card__number">03</span>
                        <h3 class="cultura-card__title">Valores</h3>
                        <p class="cultura-card__text">
                            {sobrePage.data.cultura_valores || 'Não criamos peças bonitas que não vendem. Criamos comunicação que performa com integridade e foco em resultado real.'}
                        </p>
                        <div class="cultura-card__tags">
                            <span class="cultura-tag-pill">Transparência</span>
                            <span class="cultura-tag-pill">Resultado</span>
                            <span class="cultura-tag-pill">Paixão</span>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- =========================================
             CASES DE SUCESSO — com imagens reais
        ========================================= -->
        <section class="cases-section">
            <div class="container">
                <div class="cases-header fade-in">
                    <h2 class="cases-title">Cases de sucesso</h2>
                    <p class="cases-desc">
                        Trabalhamos com marcas de diferentes portes e segmentos, entregando desde branding até campanhas completas e presença digital estratégica.
                    </p>
                </div>

                <div class="cases-grid fade-in">
                    <a href="portfolio" class="case-item">
                        <img src="/assets/images/mockup-grife.png" alt="Grife da Boutique da Carne Siltomac">
                        <div class="case-item__label">
                            <div class="case-item__tag">Branding</div>
                            <div class="case-item__name">Grife da <strong>Boutique da Carne Siltomac</strong></div>
                        </div>
                    </a>

                    <a href="portfolio" class="case-item">
                        <img src="/assets/images/portfolio-masotti.png" alt="Campanha Masotti Móveis">
                        <div class="case-item__label">
                            <div class="case-item__tag">Campanha</div>
                            <div class="case-item__name">Campanha dos 30 anos da <strong>Móveis Masotti</strong></div>
                        </div>
                    </a>

                    <a href="portfolio" class="case-item">
                        <img src="/assets/images/outdoor-dubelato-full.png" alt="Dubelato Gelateria">
                        <div class="case-item__label">
                            <div class="case-item__tag">Marketing</div>
                            <div class="case-item__name">Lançamento da <strong>Dubelato Gelateria</strong> em São Carlos</div>
                        </div>
                    </a>

                    <a href="portfolio" class="case-item">
                        <img src="/assets/images/mockup-mba-usp.png" alt="MBA IA e Big Data USP">
                        <div class="case-item__label">
                            <div class="case-item__tag">Comunicação</div>
                            <div class="case-item__name"><strong>MBA IA e Big Data — USP</strong></div>
                        </div>
                    </a>
                </div>

                <div style="text-align: center; margin-top: 3rem;">
                    <a href="portfolio" class="btn btn--primary">Ver todos os cases</a>
                </div>
            </div>
        </section>

    </main>

    <!-- Footer -->
    <footer class="footer">
        <div class="container">
            <div class="footer__grid">
                <div class="footer__brand">
                    <a href="/" class="logo logo--footer">
                        <img src="/assets/images/footer-logo.png" alt="Filomena Propaganda & Marketing" class="logo__img">
                    </a>
                    <p>Comunicação criativa que conecta.</p>
                    <span class="footer__tagline">#teamfilomena</span>
                
                    <div class="footer__socials" style="display: flex; gap: var(--space-xs); margin-top: var(--space-md);">
                        <a href="https://www.instagram.com/filomenapropaganda/" target="_blank" class="social-btn" aria-label="Instagram">
